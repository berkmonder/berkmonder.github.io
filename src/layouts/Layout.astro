---
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | muhammed berk önder</title>
    <style is:global>
      :root {
        --bg: #fff;
        --text: #111;
        --link: #0000ee;
        --link-hover: #551a8b;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #121212;
          --text: #e0e0e0;
          --link: #8ab4f8;
          --link-hover: #c58af9;
        }
      }
      body {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        background-color: var(--bg);
        color: var(--text);
        max-width: 650px;
        margin: 4rem auto;
        padding: 0 1rem;
        line-height: 1.6;
        font-size: 15px;
      }
      h1, h2, h3 {
        font-weight: normal;
        margin-top: 2em;
      }
      a {
        color: var(--link);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
        color: var(--link-hover);
      }
      nav {
        margin-bottom: 2rem;
        display: flex;
        gap: 1rem;
      }
      .post-list {
        list-style: none;
        padding: 0;
      }
      .post-list li {
        margin-bottom: 1rem;
      }
      .date {
        color: #888;
        margin-right: 0.5rem;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/">home</a>
      <a href="/about">about</a>
      <a href="/blog">blog</a>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
